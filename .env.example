# MongoDB Configuration
MONGODB_DATABASE=social_feed
# Matches the local MongoDB service in deployment/docker-compose.yml.
MONGODB_URI=mongodb://root:password@localhost:27017/?authSource=admin
MONGODB_ENABLE_MONITORING=false

# Encryption Key (Must be 32 bytes)
ENCRYPT_KEY=changeme_changeme_changeme_changeme_changeme

# JWT Secret
JWT_SECRET=changeme_changeme_changeme_changeme

# Server Configuration
APP_PORT=8080
API_MODE=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Empty means no proxy is trusted. In production set only known proxy IP/CIDRs.
TRUSTED_PROXIES=

# RabbitMQ
RABBITMQ_URL=amqp://user:password@localhost:5672/

# Logger Configuration
LOGGER_LEVEL=debug
LOGGER_MODE=development
LOGGER_ENCODING=console

# Bot Configuration
GEMINI_API_KEY=your_gemini_key

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
BOT_USER_ID=your_user_id
SCANNER_BOT_TOKEN=your_scanner_bot_token
ETHERSCAN_API_KEY=your_etherscan_key_here
BSCSCAN_API_KEY=your_bscscan_key_here
BASESCAN_API_KEY=your_basescan_key_here
ARBISCAN_API_KEY=your_arbiscan_key_here
POLYGONSCAN_API_KEY=your_polygonscan_key_here
